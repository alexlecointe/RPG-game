# App
APP_ENV=development
API_KEY=dev-local-key-change-in-production

# Database (SQLite default; set postgres URL for prod)
DATABASE_URL=sqlite+aiosqlite:///./rpg_agent.db

# Agents: mock | openai | anthropic | auto
AGENT_MODE=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Credits economy
DAILY_FREE_CREDITS=50
CREDITS_CAP=100
MISSION_REFUND_ON_FAIL_PERCENT=50

# Tools
TOOLS_ENABLED=true

# Tavily — web search
TAVILY_API_KEY=

# SerpAPI — Google Trends
SERPAPI_KEY=

# Replicate — image generation
REPLICATE_API_TOKEN=

# Ads video generation — auto | openai | replicate
# Production recommendation: ADS_VIDEO_PROVIDER=openai + OPENAI_VIDEO_MODEL=<current OpenAI video model>
OPENAI_VIDEO_MODEL=
ADS_VIDEO_PROVIDER=auto
ADS_VIDEO_R2_REQUIRED=false

# Resend — email (optional)
RESEND_API_KEY=
RESEND_FROM_DOMAIN=resend.dev

# Browserbase — headless browser
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Stripe ──────────────────────────────────────────────────────────────────
# Clé secrète principale (tous les appels Stripe)
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — /webhooks/stripe (ventes founders / Connect)
# Depuis Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Webhook secret — /webhooks/stripe/billing (abonnements / packs / God Mode)
STRIPE_BILLING_WEBHOOK_SECRET=whsec_...

# Plans d'abonnement — créer dans Stripe Dashboard > Products
# Chaque valeur = Price ID (ex: price_1xxxxxxxx)
STRIPE_PRICE_STARTER=price_   # $19/mois — 15 crédits
STRIPE_PRICE_GROWTH=price_    # $29/mois — 25 crédits
STRIPE_PRICE_PRO=price_       # $49/mois — 50 crédits
STRIPE_PRICE_SCALE=price_     # $99/mois — 100 crédits
STRIPE_PRICE_POWER=price_     # $199/mois — 200 crédits
STRIPE_PRICE_ULTRA=price_     # $499/mois — 500 crédits
STRIPE_PRICE_MAX=price_       # $999/mois — 1000 crédits

# Stripe Connect — deep links iOS
STRIPE_CONNECT_RETURN_URL=rpgagent://stripe/return
STRIPE_CONNECT_REFRESH_URL=rpgagent://stripe/refresh

# Meta — Pixel + CAPI + Ads (compte central plateforme)
META_PIXEL_ID=
META_CAPI_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=

# Branded site subdomain — e.g. drypod-6.rpgagent.app
SITE_BASE_DOMAIN=rpgagent.app

# Ads wallet platform fee (% of daily budget kept by platform)
ADS_PLATFORM_FEE_PERCENT=20

# Backend public URL (Render forward webhooks Stripe ici)
# Ex: https://ton-backend.onrender.com ou ngrok URL
BACKEND_PUBLIC_URL=

# Infrastructure — Render + Neon + GitHub
RENDER_API_KEY=
NEON_API_KEY=
GITHUB_TOKEN=
GITHUB_ORG=

# Cloudflare R2 — assets (optionnel, fallback local)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# X/Twitter — OAuth 1.0a (compte central plateforme)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Redis (Celery prod)
REDIS_URL=redis://localhost:6379/0
